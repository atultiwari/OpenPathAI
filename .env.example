# OpenPathAI environment template — copy to `.env` and fill in.
#
# `.env` is git-ignored. `scripts/run-full.sh` sources it at startup
# (key=value lines only) so secrets stay out of your shell rc.
#
# Precedence rules:
#   * Anything already exported in your shell wins over `.env`.
#   * For HF tokens, the canvas Settings → Hugging Face card always
#     wins over both — it writes to ~/.openpathai/secrets.json (mode
#     0600). Use `.env` here as the headless / CI alternative.

# ─── OpenPathAI server ─────────────────────────────────────────────

# Bearer token clients send as `Authorization: Bearer <token>`.
# Auto-generated if blank.
OPA_API_TOKEN=

# Override the default ~/.openpathai data root (cache, audit DB,
# secrets, DZI pyramids, checkpoints).
# OPENPATHAI_HOME=/path/to/openpathai-home

# Server ports.
OPA_API_PORT=7870
OPA_GUI_PORT=7860
OPA_MLFLOW_PORT=5001

# ─── Hugging Face credentials ──────────────────────────────────────

# Headless / CI alternative to the canvas Settings card. Either name
# works; HF_TOKEN wins if both are set and the settings file is
# empty. Get a token at https://huggingface.co/settings/tokens
# (a `read` token is enough for downloading gated weights).
HF_TOKEN=
# HUGGING_FACE_HUB_TOKEN=

# ─── Local LLM backend (Phase 15+) ─────────────────────────────────

# Where Ollama is reachable. Defaults to http://127.0.0.1:11434.
# OLLAMA_HOST=http://127.0.0.1:11434

# ─── run-full.sh overrides ─────────────────────────────────────────

# OPA_REBUILD_CANVAS=1     # wipe web/canvas/dist before launch
# OPA_SKIP_SYNC=1          # reuse the current .venv as-is
# OPA_SKIP_FORMAT_CHECK=1  # silence the local ruff-format guard
