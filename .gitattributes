# Normalise line endings on checkin; restore native on checkout.
* text=auto eol=lf

# Text formats
*.py       text eol=lf
*.pyi      text eol=lf
*.md       text eol=lf
*.yml      text eol=lf
*.yaml     text eol=lf
*.toml     text eol=lf
*.cfg      text eol=lf
*.ini      text eol=lf
*.json     text eol=lf
*.txt      text eol=lf
*.sh       text eol=lf
*.html     text eol=lf
*.css      text eol=lf
*.js       text eol=lf
*.ts       text eol=lf
*.tsx      text eol=lf

# Notebooks are text (JSON) — mark as such so diffs render.
*.ipynb    text eol=lf linguist-language=Python

# Binary formats — do not touch.
*.png      binary
*.jpg      binary
*.jpeg     binary
*.gif      binary
*.svg      text eol=lf
*.ico      binary
*.pdf      binary
*.pt       binary
*.pth      binary
*.h5       binary
*.safetensors binary
*.onnx     binary
*.ckpt     binary

# WSI / DICOM — binary.
*.svs      binary
*.ndpi     binary
*.mrxs     binary
*.tif      binary
*.tiff     binary
*.dcm      binary
